# Configuración del servidor SMTP
SMTP_HOST=smtp.example.com  # Servidor SMTP (ejemplo: smtp.gmail.com)
SMTP_USERNAME=usuario@example.com  # Tu dirección de correo electrónico SMTP
SMTP_PASSWORD=tu_contraseña_smtp  # Tu contraseña de aplicación SMTP
SMTP_PORT=587  # Puerto SMTP (ejemplo: 587 para TLS, 465 para SSL)

# Configuración de la base de datos
DB_HOST=localhost # El host de tu servidor de base de datos
DB_USERNAME=usuario # El nombre de usuario para conectar a la base de datos
DB_PASSWORD=contraseña # La contraseña para conectar a la base de datos
DB_DATABASE=nombre_de_la_base_de_datos # El nombre de la base de datos

# Configuración de la aplicación
APP_URL=http://localhost/Encriptacion_PHP/public
APP_TIMEZONE=America/Bogota

# Configuración de caché
CACHE_ENABLED=true
CACHE_TTL_USERS=60 # Tiempo de vida en segundos para la lista de usuarios

# Remember Me
REMEMBER_ME_ENABLED=true
REMEMBER_ME_TTL=2592000

# Session timeout (inactividad)
SESSION_TIMEOUT=1800

# Gestión de sesiones activas (revocación de sesiones)
ACTIVE_SESSIONS_ENABLED=true

# Account lockout
LOGIN_LOCKOUT_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Versión de la aplicación
APP_VERSION=1.14.1
