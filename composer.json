{
    "name": "jandrescodes/encriptacion-php",
    "description": "PHP MVC custom auth system with bcrypt and email recovery",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-mysqli": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Lib\\": "libs/"
        },
        "files": [
            "app/Config/config.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":             "phpunit",
        "test:unit":        "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
